---
const currentYear = new Date().getFullYear();
---

<footer>
	<div class="group">
		<p>
			&copy; {currentYear} Gisella Farinini. Tutti i diritti riservati. Powered by RCP
		</p>
	</div>
</footer>

<style>
	footer {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-top: auto;
		padding: 2rem;
		text-align: center;
		color: var(--color-gray);
		font-size: 0.875rem;
		background: var(--color-black);
		border-top: 1px solid rgba(201, 169, 97, 0.2);
	}

	.group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		align-items: center;
	}

	.powered-by {
		color: var(--color-gold);
		font-size: 0.75rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	@media (min-width: 50em) {
		footer {
			padding: 2rem 5rem;
		}
	}
</style>
