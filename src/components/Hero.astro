---
---

<section class="hero">
  <div class="hero-content">
    <p class="hero-label">Pittrice</p>
    <h1 class="hero-title">
      <span class="title-line">Gisella</span>
      <span class="title-line gold">Farinini</span>
    </h1>
    
    <p class="hero-subtitle">
      Un intreccio di esuberanza, introversione, solitudine, irrequietezza, 
      serenità, amore per il prossimo e gioia di vivere
    </p>
    
    <div class="hero-cta">
      <a href="#galleria" class="btn-primary">Esplora le Opere</a>
      <a href="#biografia" class="btn-secondary">Biografia</a>
    </div>
  </div>
  
  <div class="hero-visual">
    <div class="artwork-preview">
      <img src="/images/01-bisbiglii-2024.jpg" alt="Bisbiglii tra le rocce" />
      <div class="artwork-info">
        <span class="artwork-title">"Bisbiglii tra le rocce"</span>
        <span class="artwork-year">2024</span>
      </div>
    </div>
  </div>
  
  <div class="scroll-indicator">
    <span>Scorri</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 2rem 4rem;
    position: relative;
    background: linear-gradient(135deg, var(--color-black) 0%, var(--color-black-light) 100%);
  }
  
  .hero-content {
    padding-right: 4rem;
    z-index: 2;
  }
  
  .hero-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--color-gold);
    margin-bottom: 1.5rem;
  }
  
  .hero-title {
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 1;
    margin-bottom: 2rem;
  }
  
  .title-line {
    display: block;
  }
  
  .title-line.gold {
    color: var(--color-gold);
    font-style: italic;
  }
  
  .hero-subtitle {
    font-size: 1rem;
    font-weight: 300;
    color: var(--color-gray);
    max-width: 500px;
    margin-bottom: 3rem;
    line-height: 1.8;
  }
  
  .hero-cta {
    display: flex;
    gap: 1.5rem;
  }
  
  .btn-primary {
    background: var(--color-gold);
    color: var(--color-black);
    padding: 1rem 2.5rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    transition: all 0.3s ease;
    border: 1px solid var(--color-gold);
  }
  
  .btn-primary:hover {
    background: transparent;
    color: var(--color-gold);
  }
  
  .btn-secondary {
    background: transparent;
    color: var(--color-white);
    padding: 1rem 2.5rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    border: 1px solid var(--color-white);
    transition: all 0.3s ease;
  }
  
  .btn-secondary:hover {
    background: var(--color-white);
    color: var(--color-black);
  }
  
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }
  
  .artwork-preview {
    position: relative;
    width: 80%;
    max-width: 500px;
  }
  
  .artwork-preview img {
    width: 100%;
    height: auto;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5);
    transition: transform 0.5s ease;
  }
  
  .artwork-preview:hover img {
    transform: scale(1.02);
  }
  
  .artwork-info {
    position: absolute;
    bottom: -3rem;
    left: -2rem;
    background: var(--color-black-light);
    padding: 1.5rem 2rem;
    border-left: 3px solid var(--color-gold);
  }
  
  .artwork-title {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    color: var(--color-white);
    margin-bottom: 0.25rem;
  }
  
  .artwork-year {
    font-size: 0.75rem;
    color: var(--color-gold);
    letter-spacing: 0.1em;
  }
  
  .scroll-indicator {
    position: absolute;
    bottom: 3rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  
  .scroll-indicator span {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-gray);
  }
  
  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--color-gold), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  
  @keyframes scrollPulse {
    0%, 100% { opacity: 1; transform: scaleY(1); }
    50% { opacity: 0.5; transform: scaleY(0.8); }
  }
  
  @media (max-width: 968px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 6rem 2rem;
      gap: 4rem;
    }
    
    .hero-content {
      padding-right: 0;
      text-align: center;
    }
    
    .hero-cta {
      justify-content: center;
    }
    
    .artwork-info {
      left: 0;
      right: 0;
      bottom: -2rem;
    }
  }
</style>
