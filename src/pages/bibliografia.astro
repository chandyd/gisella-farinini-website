    ]
  },
  {
    year: "2010",
    items: ["Catalogo \"I colori dal mondo\" a cura di Eva Czerkl"]
  },
  {
    year: "2015",
    items: [
      "Effetto Arte – n° 6 a cura di Paolo Levi – Ea Editore",
      "Arte n° 501 – Editoriale Giorgio Mondadori",
      "Arte n° 503 – Editoriale Giorgio Mondadori",
      "Arte n° 505 – Editoriale Giorgio Mondadori",
      "Arte n° 506 – Editoriale Giorgio Mondadori",
      "Arte n° 508 – Editoriale Giorgio Mondadori",
      "Arte n° 509 – Editoriale Giorgio Mondadori",
      "Catalogo dell'Arte Moderna n° 51 – Editoriale Giorgio Mondadori",
      "Effetto Arte – rubrica \"Marco Polo International Price Ambasciatore dell'Arte\" – Ea Editore"
    ]
  },
  {
    year: "2016",
    items: [
      "\"Maestri – Selezione d'Arte Contemporanea\" – Ea Editore",
      "\"Guida Regionale al Mondo dell'Arte\" – Ed. Millenium Effetto Arte – Ea Editore",
      "\"Italiani\" a cura di Vittorio Sgarbi – Ea Editore",
      "Arte n° 513 – Editoriale Giorgio Mondadori",
      "Catalogo dell'Arte Moderna n° 52 – Editoriale Giorgio Mondadori"
    ]
  },
  {
    year: "2017",
    items: [
      "Catalogo \"Dal Passato al Presente, quando l'Arte celebra la Vita\" a cura di Paolo Levi – Ea Editore",
      "Volume \"Pittori e Scultori\" a cura di Giorgio Falossi – Lorenzo Cipriani – Casa Editrice Il Quadrato"
    ]
  }
];
---

<Layout title="Bibliografia | Gisella Farinini">
  <Header slot="header" />
  
  <main class="page-content">
    <section class="page-header">
      <div class="container">
        <p class="section-label">Pubblicazioni</p>
        <h1>Bibliografia</h1>
      </div>
    </section>
    
    <section class="bibliography">
      <div class="container">
        {bibliography.map(entry => (
          <div class="bib-year">
            <h2 class="year-title">{entry.year}</h2>
            <ul class="bib-list">
              {entry.items.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  .page-header {
    padding: 12rem 0 4rem;
    text-align: center;
    background: linear-gradient(180deg, var(--color-black-light) 0%, var(--color-black) 100%);
  }
  
  .section-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }
  
  .page-header h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
  }
  
  .bibliography {
    padding: 6rem 0;
    background: var(--color-black);
  }
  
  .bib-year {
    margin-bottom: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(201, 169, 97, 0.2);
  }
  
  .bib-year:last-child {
    border-bottom: none;
  }
  
  .year-title {
    font-size: 2rem;
    color: var(--color-gold);
    margin-bottom: 1.5rem;
  }
  
  .bib-list {
    list-style: none;
    display: grid;
    gap: 1rem;
  }
  
  .bib-list li {
    font-size: 1rem;
    color: var(--color-gray);
    padding-left: 1.5rem;
    position: relative;
    line-height: 1.6;
  }
  
  .bib-list li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-gold);
  }
  
  @media (max-width: 768px) {
    .bibliography {
      padding: 4rem 0;
    }
    
    .bib-year {
      margin-bottom: 3rem;
      padding-bottom: 2rem;
    }
  }
</style>
