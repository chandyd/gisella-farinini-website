---
// Gisella Farinini - Museum Quality Portfolio
// Versione 2.0 - Deploy: 31 Marzo 2026
---

<!DOCTYPE html>
<html lang="it" class="scroll-smooth">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gisella Farinini | Pittrice Contemporanea</title>
    <meta name="description" content="Portfolio ufficiale di Gisella Farinini, pittrice contemporanea con coefficiente artistico 5.6. Olio su tela dal 1994.">
    <meta name="keywords" content="Gisella Farinini, pittrice, arte contemporanea, olio su tela, Liguria, coefficiente artistico">
    <meta name="author" content="Gisella Farinini">
    <meta property="og:title" content="Gisella Farinini | Pittrice Contemporanea">
    <meta property="og:description" content="Portfolio ufficiale di Gisella Farinini, pittrice contemporanea con coefficiente artistico 5.6">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://gisellafarinini.com">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
      /* Critical CSS inline per performance */
      :root {
        --color-black: #0a0a0a;
        --color-black-light: #141414;
        --color-gold: #c9a961;
        --color-gold-light: #dccba3;
        --color-white: #f5f5f5;
        --color-gray: #888888;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { 
        font-family: 'Inter', sans-serif; 
        background: var(--color-black); 
        color: var(--color-white);
        overflow-x: hidden;
      }
    </style>
  </head>
  <body>
    <!-- Loading Screen -->
    <div id="loading-screen" style="position:fixed;inset:0;background:var(--color-black);z-index:99999;display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity 0.6s ease;">
      <div style="font-family:'Playfair Display', serif;font-size:2rem;color:var(--color-gold);margin-bottom:1rem;">Gisella Farinini</div>
      <div style="width:200px;height:2px;background:rgba(201,169,97,0.2);border-radius:1px;overflow:hidden;">
        <div id="loading-progress" style="width:0%;height:100%;background:var(--color-gold);transition:width 0.3s ease;"></div>
      </div>
    </div>

    <!-- Navigation -->
    <header id="header" style="position:fixed;top:0;left:0;right:0;z-index:1000;padding:1.5rem 2rem;transition:all 0.4s ease;">
      <nav style="max-width:1400px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;">
        <a href="#" style="font-family:'Playfair Display', serif;font-size:1.5rem;color:var(--color-white);text-decoration:none;font-weight:600;">
          Gisella <span style="color:var(--color-gold);">Farinini</span>
        </a>
        
        <!-- Desktop Menu -->
        <ul id="desktop-menu" style="display:flex;gap:2.5rem;list-style:none;">
          {['Galleria', 'Biografia', 'CV', 'Filosofia', 'Contatti'].map(item => (
            <li><a href={`#${item.toLowerCase()}`} style="color:var(--color-white);text-decoration:none;font-size:0.9rem;font-weight:500;position:relative;transition:color 0.3s ease;">{item}</a></li>
          ))}
        </ul>

        <!-- Mobile Menu Button -->
        <button id="mobile-menu-btn" aria-label="Menu" style="display:none;background:none;border:none;cursor:pointer;padding:0.5rem;">
          <span style="display:block;width:24px;height:2px;background:var(--color-white);margin:5px 0;transition:0.3s;"></span>
          <span style="display:block;width:24px;height:2px;background:var(--color-white);margin:5px 0;transition:0.3s;"></span>
          <span style="display:block;width:24px;height:2px;background:var(--color-white);margin:5px 0;transition:0.3s;"></span>
        </button>
      </nav>
      
      <!-- Mobile Menu -->
      <div id="mobile-menu" style="display:none;position:fixed;inset:0;background:rgba(10,10,10,0.98);padding-top:100px;">
        <ul style="list-style:none;text-align:center;">
          {['Galleria', 'Biografia', 'CV', 'Filosofia', 'Contatti'].map(item => (
            <li style="margin:1.5rem 0;"><a href={`#${item.toLowerCase()}`} style="color:var(--color-white);text-decoration:none;font-size:1.5rem;font-family:'Playfair Display', serif;">{item}</a></li>
          ))}
        </ul>
      </div>
    </header>

    <!-- Hero Section -->
    <section id="hero" style="min-height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:center;position:relative;overflow:hidden;padding:2rem;">
      <!-- Background Slideshow -->
      <div id="hero-slideshow" style="position:absolute;inset:0;z-index:0;">
        <div class="slide active" style="position:absolute;inset:0;background:url('/images/bisbiglii-tra-le-rocce.jpg') center/cover no-repeat;opacity:1;transform:scale(1);transition:opacity 1s ease,transform 8s ease;"></div>
        <div class="slide" style="position:absolute;inset:0;background:url('/images/nel-cuore-del-mistero.jpg') center/cover no-repeat;opacity:0;transform:scale(1.1);transition:opacity 1s ease,transform 8s ease;"></div>
        <div class="slide" style="position:absolute;inset:0;background:url('/images/meta.jpg') center/cover no-repeat;opacity:0;transform:scale(1.1);transition:opacity 1s ease,transform 8s ease;"></div>
      </div>
      
      <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(10,10,10,0.3),rgba(10,10,10,0.7));z-index:1;"></div>

      <div style="position:relative;z-index:2;text-align:center;max-width:900px;">
        <p style="font-size:0.9rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--color-gold);margin-bottom:1.5rem;opacity:0;animation:fadeInUp 1s ease 0.5s forwards;">Pittrice Contemporanea</p>
        
        <h1 style="font-family:'Playfair Display', serif;font-size:clamp(3rem,8vw,6rem);font-weight:400;line-height:1.1;margin-bottom:1.5rem;">
          <span style="display:block;opacity:0;animation:fadeInUp 1s ease 0.7s forwards;">Gisella</span>
          <span style="display:block;color:var(--color-gold);opacity:0;animation:fadeInUp 1s ease 0.9s forwards;">Farinini</span>
        </h1>
        
        <p style="font-size:1.1rem;color:var(--color-gray);max-width:600px;margin:0 auto 2rem;line-height:1.7;opacity:0;animation:fadeInUp 1s ease 1.1s forwards;">
          Un intreccio di esuberanza, introversione, solitudine, irrequietezza, serenità, amore per il prossimo e gioia di vivere
        </p>

        <!-- Coefficiente Badge -->
        <div style="display:inline-flex;align-items:center;gap:1rem;background:rgba(201,169,97,0.1);border:1px solid var(--color-gold);padding:0.75rem 1.5rem;border-radius:50px;margin-bottom:2.5rem;opacity:0;animation:fadeInUp 1s ease 1.3s forwards;">
          <span style="font-family:'Playfair Display', serif;font-size:1.5rem;color:var(--color-gold);">5.6</span>
          <span style="font-size:0.8rem;color:var(--color-gray);text-align:left;">Coefficiente Artistico<br/>Assegnato dalla Critica</span>
        </div>

        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;opacity:0;animation:fadeInUp 1s ease 1.5s forwards;">
          <a href="#galleria" style="background:var(--color-gold);color:var(--color-black);padding:1rem 2rem;text-decoration:none;font-weight:500;border-radius:4px;transition:all 0.3s ease;">Esplora le Opere</a>
          <a href="#biografia" style="border:1px solid var(--color-white);color:var(--color-white);padding:1rem 2rem;text-decoration:none;font-weight:500;border-radius:4px;transition:all 0.3s ease;">Biografia</a>
        </div>
      </div>

      <!-- Scroll Indicator -->
      <a href="#galleria" style="position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);z-index:2;display:flex;flex-direction:column;align-items:center;color:var(--color-white);text-decoration:none;font-size:0.8rem;letter-spacing:0.1em;opacity:0;animation:fadeInUp 1s ease 2s forwards, bounce 2s infinite;">
        <span style="margin-bottom:0.5rem;">Scorri</span>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 5v14M19 12l-7 7-7-7"/>
        </svg>
      </a>
    </section>

    <!-- Gallery Section -->
    <section id="galleria" style="padding:8rem 2rem;background:var(--color-black);">
      <div style="max-width:1400px;margin:0 auto;">
        <div style="text-align:center;margin-bottom:4rem;">
          <p style="color:var(--color-gold);font-size:0.9rem;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:1rem;">Portfolio</p>
          <h2 style="font-family:'Playfair Display', serif;font-size:clamp(2.5rem,5vw,4rem);margin-bottom:1rem;">Dipinti</h2>
          <p style="color:var(--color-gray);max-width:600px;margin:0 auto;">Una selezione di opere dal 1994 al 2024, olio su tela</p>
        </div>

        <!-- Filters -->
        <div style="display:flex;justify-content:center;gap:1rem;margin-bottom:3rem;flex-wrap:wrap;">
          {['Tutti', '2022-2024', '2016-2017', '2001-2005', '1994-1999'].map((filter, i) => (
            <button class={`filter-btn ${i === 0 ? 'active' : ''}`} data-filter={filter} style={`padding:0.5rem 1.5rem;border:1px solid ${i === 0 ? 'var(--color-gold)' : 'rgba(255,255,255,0.2)'};background:${i === 0 ? 'var(--color-gold)' : 'transparent'};color:${i === 0 ? 'var(--color-black)' : 'var(--color-white)'};border-radius:50px;cursor:pointer;transition:all 0.3s ease;`}>
              {filter}
            </button>
          ))}
        </div>

        <!-- Gallery Grid -->
        <div id="gallery-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:2rem;">
          <!-- Artwork cards will be inserted via JavaScript -->
        </div>
      </div>
    </section>

    <!-- Biography Section -->
    <section id="biografia" style="padding:8rem 2rem;background:var(--color-black-light);">
      <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;">
        
        <div style="position:relative;">
          <div style="position:relative;overflow:hidden;border-radius:8px;">
            <img src="/images/gisella-portrait.jpg" alt="Gisella Farinini" style="width:100%;height:auto;display:block;transition:transform 0.6s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'"/>
          </div>
          <div style="position:absolute;bottom:-20px;right:-20px;background:var(--color-gold);color:var(--color-black);padding:1.5rem;border-radius:8px;text-align:center;">
            <span style="font-family:'Playfair Display', serif;font-size:2rem;display:block;">30+</span>
            <span style="font-size:0.8rem;">Anni di Attività</span>
          </div>
        </div>

        <div>
          <p style="color:var(--color-gold);font-size:0.9rem;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:1rem;">L'Artista</p>
          
          <h2 style="font-family:'Playfair Display', serif;font-size:clamp(2rem,4vw,3rem);margin-bottom:2rem;">Biografia</h2>
          
          <p style="color:var(--color-gray);line-height:1.8;margin-bottom:1.5rem;">
            Mi chiamo Gisella e sin da piccola ho sempre desiderato divertirmi con i colori e altri materiali. Questo sito è una piccola vetrina di alcuni dei miei dipinti che sono la traduzione del mio essere: <strong style="color:var(--color-white);">un intreccio di esuberanza, introversione, solitudine, irrequietezza, serenità, amore per il prossimo e gioia di vivere</strong>, nonostante le forti asperità della vita.
          </p>
          
          <p style="color:var(--color-gray);line-height:1.8;margin-bottom:1.5rem;">
            Dal 1994, anno della mia prima opera "Occhio di Liguria", fino ad oggi, ho cercato di esprimere attraverso la pittura le emozioni, i paesaggi e le sensazioni che la vita mi regala.
          </p>

          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;margin-top:3rem;">
            <div style="text-align:center;">
              <span style="font-family:'Playfair Display', serif;font-size:2.5rem;color:var(--color-gold);">34</span>
              <p style="font-size:0.8rem;color:var(--color-gray);">Opere</p>
            </div>
            <div style="text-align:center;">
              <span style="font-family:'Playfair Display', serif;font-size:2.5rem;color:var(--color-gold);">36</span>
              <p style="font-size:0.8rem;color:var(--color-gray);">Critici</p>
            </div>
            <div style="text-align:center;">
              <span style="font-family:'Playfair Display', serif;font-size:2.5rem;color:var(--color-gold);">5.6</span>
              <p style="font-size:0.8rem;color:var(--color-gray);">Coefficiente</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <style>
      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes bounce {
        0%, 100% { transform: translateX(-50%) translateY(0); }
        50% { transform: translateX(-50%) translateY(10px); }
      }
      @media (max-width: 768px) {
        #desktop-menu { display: none !important; }
        #mobile-menu-btn { display: block !important; }
        #biografia > div { grid-template-columns: 1fr !important; }
      }
    </style>

    <script>
      // Loading screen
      window.addEventListener('load', () => {
        const progress = document.getElementById('loading-progress');
        const screen = document.getElementById('loading-screen');
        progress.style.width = '100%';
        setTimeout(() => {
          screen.style.opacity = '0';
          setTimeout(() => screen.remove(), 600);
        }, 500);
      });

      // Header scroll effect
      const header = document.getElementById('header');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 100) {
          header.style.background = 'rgba(10,10,10,0.95)';
          header.style.backdropFilter = 'blur(10px)';
          header.style.padding = '1rem 2rem';
        } else {
          header.style.background = 'transparent';
          header.style.backdropFilter = 'none';
          header.style.padding = '1.5rem 2rem';
        }
      });

      // Slideshow
      const slides = document.querySelectorAll('.slide');
      let currentSlide = 0;
      setInterval(() => {
        slides[currentSlide].style.opacity = '0';
        slides[currentSlide].style.transform = 'scale(1.1)';
        currentSlide = (currentSlide + 1) % slides.length;
        slides[currentSlide].style.opacity = '1';
        slides[currentSlide].style.transform = 'scale(1)';
      }, 5000);
    </script>
  </body>
</html>
