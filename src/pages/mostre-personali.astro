---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const exhibitions = [
  { year: "1994", title: "I miei colori", location: "Centro Culturale Nicolò Barabino – Genova Sampierdarena" },
  { year: "1995", title: "Viaggio introspettivo", location: "Istituto Brignole Sale – Genova" },
  { year: "1995", title: "I colori di campagna", location: "Galleria Spazio e Arte – Gavi (AL)" },
  { year: "1995", title: "Il mare dei miei sogni", location: "Azienda Autonoma Turismo e Soggiorno – Positano (SA)" },
  { year: "1995", title: "Percorso nel verde", location: "Associazione Culturale Art Group – Lido degli Estensi (FE)" },
  { year: "1995", title: "Scintillii nel buio", location: "Chiesa SS. Trinità – S. Salvatore Monferrato" },
  { year: "1996", title: "Ombre", location: "Caffè degli Specchi – Genova" },
  { year: "1996", title: "Le mie espressioni in arte", location: "Circolo Ufficiali del Presidio Militare di Genova" },
  { year: "1997", title: "Mostra personale", location: "Università Popolare Sestrese – Genova Sestri" },
  { year: "1998", title: "Passioni e Sensazioni", location: "Villa S. Giacomo – S. Margherita Ligure (GE)" },
  { year: "2000", title: "Contemplazione della Natura", location: "Galleria Il Leudo – Genova" },
  { year: "2000", title: "Mostra mercato d'arte moderna", location: "Nuovo Palacongressi – Expo Arte Jesolo" },
  { year: "2000", title: "Proposte d'arte contemporanea", location: "Lingotto Fiere – Artincontri – Torino" },
  { year: "2000", title: "Artisti a Torino", location: "Palazzo Nervi – Torino" },
  { year: "2000", title: "Mostra mercato d'arte", location: "Quartiere fieristico – Forlì" },
  { year: "2000", title: "Arte Padova", location: "Padova Fiere – Undicesima mostra mercato" },
  { year: "2000", title: "Artisti in Fiera", location: "Arte Europa Parma" },
  { year: "2001", title: "Artisti a Torino", location: "Palazzo Nervi – Seconda edizione – Torino" },
  { year: "2002", title: "Colore e Poesia", location: "Fondazione Palazzo Viani Visconti – Pallanza (VB)" },
  { year: "2002", title: "Ricerche Figurative", location: "Galleria Il Canovaccio – Roma" },
  { year: "2002", title: "Nel silenzio della Natura", location: "Castello dei Ventimiglia – Borgomaro (IM)" },
  { year: "2002", title: "Il senso della materia", location: "Foyer Teatro Verdi – Fiorenzuola D'Arda (PC)" },
  { year: "2002", title: "La forza del colore", location: "Galleria d'Arte Studio C – Piacenza" },
  { year: "2003", title: "I luoghi dell'anima", location: "Galleria Cassiopea di Anny Baldissera – Roma" },
  { year: "2003", title: "Colori e Passioni", location: "Galleria Art Point Black – Firenze" },
  { year: "2004", title: "Mostra personale", location: "Galleria Cà D'oro – Piazza di Spagna – Roma" },
  { year: "2006", title: "I cromatismi psicologici", location: "Piazzetta dell'Arte – Deiva Marina (SP)" },
  { year: "2008", title: "Sinfonia di colori", location: "Piazzetta dell'Arte – Deiva Marina (SP)" },
  { year: "2012", title: "Caleidoscopio di colori", location: "Palazzo Comunale di Tolfa (RM)" },
  { year: "2013", title: "Tripudio di colori", location: "A.C. Un'Orchidea nel Deserto – Cerveteri" },
  { year: "2013", title: "Colori in movimento", location: "Chiostro degli Agostiniani – Bracciano (RM)" },
  { year: "2014", title: "Giochi intensi di colori", location: "A.C. Un'Orchidea nel Deserto – Cerveteri" },
  { year: "2016", title: "Triennale dell'Arte Contemporanea", location: "Palaexpo di Verona" },
  { year: "2017", title: "Contemporanei", location: "Sale del Bramante – Roma" },
  { year: "2019", title: "Rinascimento contemporaneo", location: "Palazzo della Cancelleria del Vaticano – Roma" },
];

// Raggruppa per periodo
const grouped = exhibitions.reduce((acc, ex) => {
  if (!acc[ex.year]) acc[ex.year] = [];
  acc[ex.year].push(ex);
  return acc;
}, {});
---

<Layout title="Mostre Personali | Gisella Farinini">
  <Header slot="header" />
  
  <main class="page-content">
    <section class="page-header">
      <div class="container">
        <p class="section-label">Esibizioni</p>
        <h1>Mostre Personali</h1>
      </div>
    </section>
    
    <section class="exhibitions">
      <div class="container">
        {Object.entries(grouped).map(([year, items]) => (
          <div class="exhibition-year">
            <span class="year-badge">{year}</span>
            <div class="exhibition-list">
              {items.map(ex => (
                <div class="exhibition-item">
                  <h3>{ex.title}</h3>
                  <p>{ex.location}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  .page-header {
    padding: 12rem 0 4rem;
    text-align: center;
    background: linear-gradient(180deg, var(--color-black-light) 0%, var(--color-black) 100%);
  }
  
  .section-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }
  
  .page-header h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
  }
  
  .exhibitions {
    padding: 6rem 0;
    background: var(--color-black);
  }
  
  .exhibition-year {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(201, 169, 97, 0.2);
  }
  
  .exhibition-year:last-child {
    border-bottom: none;
  }
  
  .year-badge {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-gold);
    font-family: 'Cormorant Garamond', serif;
  }
  
  .exhibition-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .exhibition-item {
    padding: 1.5rem;
    background: var(--color-black-light);
    border-left: 3px solid var(--color-gold);
  }
  
  .exhibition-item h3 {
    font-size: 1.1rem;
    color: var(--color-white);
    margin-bottom: 0.5rem;
  }
  
  .exhibition-item p {
    font-size: 0.9rem;
    color: var(--color-gray);
  }
  
  @media (max-width: 768px) {
    .exhibitions {
      padding: 4rem 0;
    }
    
    .exhibition-year {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
