  ]},
  { year: "2004", items: ["Galleria \"Il Canovaccio\" – Roma"] },
  { year: "2005", items: ["Galleria Palazzo Margutta – \"Stili a confronto\" – Roma"] },
  { year: "2010", items: ["Centro Internazionale OAD – \"I Colori dal Mondo\" – Roma"] },
  { year: "2011", items: ["Castello di Santa Severa – Santa Severa (RM)"] },
  { year: "2012", items: [
    "A.C. Un'Orchidea nel Deserto – \"Tripudio di Colori\" – Cerveteri",
    "A.C. Un'Orchidea nel Deserto – \"Arti a Confronto\" – Cerveteri"
  ]},
  { year: "2013", items: ["Hofficina d'Arte – \"Percorsi dell'Arte\" – Roma"] },
