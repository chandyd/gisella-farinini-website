  ]},
  { year: "1999", items: [
    "Galleria d'Arte Angelo Galasso – Alba (CN)",
    "Museo Martini – Biblioteca civica – Vado (SV)"
  ]},
  { year: "2000", items: [
    "Gruppo del vento – \"VI Rassegna\" – Tenuta Presidenziale di San Rossore (PI)",
    "U.C.A.I. – \"La Fede nell'Arte\" – Genova",
    "Società Promotrice – \"Il calendario 2000\" – Bogliasco (GE)",
    "Comune di Arenzano – \"Florart\" – Arenzano (GE)",
    "Sala Compere di Palazzo San Giorgio – \"Sorella Acqua\" – Genova",
    "Atelier d'Arte – \"Rassegna di Pittori Contemporanei\" – Piacenza",
    "Palazzo dei congressi – Salsomaggiore Terme (PR)",
    "U.C.A.I. – Chiostro del Quadrivium – Genova"
  ]},
  { year: "2002", items: [
    "Galleria IX Colonne – \"Esplosioni Cromatiche\" – Bologna",
    "Art Point Black – Banca Popolare di Milano – Roma",
    "Galleria Logos – Roma"
  ]},
  { year: "2003", items: [
    "Galleria d'Arte Studio C – \"Pittura di paesaggio\" – Piacenza",
    "Palagio di Parte Guelfa – Firenze",
    "Galleria Ca' D'Oro – Roma",
