    "Civica Galleria D'Arte Moderna – \"Giuseppe Sciortino\" – Monreale (PA)",
    "Palazzo Fruscione – \"Arte Salerno\" – Salerno",
    "Palazzo Clerici – Sala Leopoldo Pirelli – Milano",
    "Milano, Hollywood – Arte States",
    "New York – Arte States",
    "Washington – Arte States"
  ]},
  { year: "2017", items: [
    "Teatro dal Verme – \"Premio internazionale arte Milano\" – Milano",
    "Museo Levi – Prima Biennale d'Arte Internazionale del Mediterraneo – Palermo",
    "Museo Europeo d'Arte Moderna – Seconda biennale di Barcellona",
    "Museo Francesco Gonzaga – Biennale Internazionale – Mantova"
  ]},
  { year: "2018", items: ["Teatro Biondo – 1° Premio Internazionale Arte Palermo"] },
  { year: "2019", items: ["Premio Cultura Identità – La Spezia"] },
  { year: "2021", items: [
    "Premio Vittorio Sgarbi – Palermo",
    "Premio d'Arte Internazionale Dante Alighieri – Casale Monferrato – Firenze",
    "Premio Internazionale Isabella D'Este – Ferrara"
  ]},
  { year: "2022", items: ["Von Zeidler Art Gallery – Primo Premio Città di Berlino"] },
  { year: "2023", items: [
    "Centro multimediale Mario Cacace – \"Eden Paradiso\" – Anacapri",
    "Teatro Ariston – Gran premio stampa artistica – Sanremo"
  ]},
];
---

<Layout title="Mostre Collettive | Gisella Farinini">
  <Header slot="header" />
  
  <main class="page-content">
    <section class="page-header">
      <div class="container">
        <p class="section-label">Esibizioni</p>
        <h1>Mostre Collettive</h1>
      </div>
    </section>
    
    <section class="exhibitions">
      <div class="container">
        {exhibitions.map(entry => (
          <div class="exhibition-year">
            <span class="year-badge">{entry.year}</span>
            <ul class="exhibition-list">
              {entry.items.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  .page-header {
    padding: 12rem 0 4rem;
    text-align: center;
    background: linear-gradient(180deg, var(--color-black-light) 0%, var(--color-black) 100%);
  }
  
  .section-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }
  
  .page-header h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
  }
  
  .exhibitions {
    padding: 6rem 0;
    background: var(--color-black);
  }
  
  .exhibition-year {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(201, 169, 97, 0.2);
  }
  
  .exhibition-year:last-child {
    border-bottom: none;
  }
  
  .year-badge {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-gold);
    font-family: 'Cormorant Garamond', serif;
  }
  
  .exhibition-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  
  .exhibition-list li {
    font-size: 1rem;
    color: var(--color-gray);
    padding-left: 1.5rem;
    position: relative;
  }
  
  .exhibition-list li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-gold);
  }
  
  @media (max-width: 768px) {
    .exhibitions {
      padding: 4rem 0;
    }
    
    .exhibition-year {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>
